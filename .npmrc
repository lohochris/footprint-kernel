# ============================================
# Footprint Manager - npm Configuration
# ============================================

# Use exact versions (no ^ or ~) for reproducible builds
save-exact=true

# Enable strict engine checks (Node version)
engine-strict=true

# Legacy peer dependencies (set to false for strict mode)
legacy-peer-deps=false

# Audit level for security checks
audit-level=high

# Disable package-lock.json for projects using package-lock.json
# (leave commented to keep package-lock.json)

# Use the new package-lock.json format (v3)
lockfile-version=3

# Set registry to default npm registry (or custom if needed)
registry=https://registry.npmjs.org/

# Disable update notifications
update-notifier=false

# Fund messages (disable to reduce noise)
fund=false

# Optional: Cache configuration (uncomment if needed)
# cache=/path/to/.npm-cache

# Optional: Use npm ci for CI/CD (automatically handled)